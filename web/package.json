{
  "name": "claude-comms-web",
  "version": "0.1.0",
  "description": "Claude Comms web client — Obsidian Forge design",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "build:check": "npm run build && npm run check:bundle-size",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run tests/a11y.spec.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "bits-ui": "^2.16.4",
    "diff": "8.0.1",
    "dompurify": "3.4.1",
    "lucide-svelte": "^1.0.1",
    "marked": "18.0.2",
    "marked-highlight": "2.2.4",
    "mqtt": "^5.10.0",
    "shiki": "3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/svelte": "5.3.1",
    "@vitest/ui": "4.1.5",
    "axe-core": "4.11.3",
    "jsdom": "29.0.2",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.0",
    "vitest": "4.1.5"
  }
}
